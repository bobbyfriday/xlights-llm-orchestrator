    <model name="Snowflake 1" DisplayAs="Custom" StringType="RGB Nodes"
           CustomModel="1,2,3;4,5,6;7,8,9" WorldPosX="-12" WorldPosY="30"/>
  </models>
  <modelGroups>
    <modelGroup name="All Arches" models="Arch L3,Arch L2,Arch L1,Arch R1,Arch R2,Arch R3"/>
  </modelGroups>
</xrgb>
