    <model name="Gutter R" DisplayAs="Single Line" StringType="RGB Nodes" parm1="1" parm2="50"
           WorldPosX="20" WorldPosY="38"/>
    <!-- a window frame (DisplayAs map) -->
    <model name="Front Window" DisplayAs="Window Frame" StringType="RGB Nodes" parm1="1" parm2="40"
           WorldPosX="0" WorldPosY="25"/>
