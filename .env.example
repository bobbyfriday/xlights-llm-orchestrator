# ─────────────────────────────────────────────────────────────────────────────
# xLights LLM Orchestrator — environment template.
# Copy to .env and fill in. .env is gitignored; never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# --- xLights automation API (required for read/write/orchestration) ----------
# xLights must be running with the automation/REST listener enabled
# (Preferences → Output → xFade port → A). Instance "A" = 49913, "B" = 49914.
XLIGHTS_BASE_URL=http://127.0.0.1:49913

# --- LLM provider (needed only for the LIVE orchestrator run) -----------------
# The orchestrator needs its OWN key — it cannot reuse the Claude Code session.
# Provide at least one; the model registry routes agent roles to whichever is set.
#   Anthropic (Claude): https://console.anthropic.com  (pay-per-token)
ANTHROPIC_API_KEY=
#   Google (Gemini): https://aistudio.google.com/app/apikey  (has a free tier)
GEMINI_API_KEY=

# --- Audio analysis (optional) ------------------------------------------------
# Where SongAnalysis results are cached (defaults to data/analyses if unset).
XLO_CACHE_DIR=data/analyses

# --- Observability (optional) -------------------------------------------------
# Pydantic Logfire token for agent tracing; leave blank to disable.
LOGFIRE_TOKEN=

# --- Audio enrichment fast-follow (④b — not used yet; optional) ---------------
# Lyrics (Genius): https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=
# Track identification (AcoustID): https://acoustid.org/new-application
ACOUSTID_API_KEY=
