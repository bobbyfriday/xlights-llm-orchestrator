<?xml version="1.0" encoding="UTF-8"?>
<!-- Authored fixture for F-E classifier/spatial tests. NOT captured from memory:
     every attribute here is exercised by an assertion in tests/test_layout_classify.py. -->
<xrgb>
  <models>
    <!-- a mega tree: Tree 360, 1600 nodes (>= 600) -->
    <model name="Mega Tree" DisplayAs="Tree 360" StringType="RGB Nodes"
           parm1="16" parm2="100" WorldPosX="0" WorldPosY="0"/>
    <!-- 6 mirrored arches, left-to-right; symmetric about x=0 -->
    <model name="Arch L3" DisplayAs="Arches" StringType="RGB Nodes" parm1="1" parm2="25"
           WorldPosX="-30" WorldPosY="1"/>
    <model name="Arch L2" DisplayAs="Arches" StringType="RGB Nodes" parm1="1" parm2="25"
           WorldPosX="-18" WorldPosY="1"/>
    <model name="Arch L1" DisplayAs="Arches" StringType="RGB Nodes" parm1="1" parm2="25"
           WorldPosX="-6" WorldPosY="1"/>
    <model name="Arch R1" DisplayAs="Arches" StringType="RGB Nodes" parm1="1" parm2="25"
           WorldPosX="6" WorldPosY="1"/>
    <model name="Arch R2" DisplayAs="Arches" StringType="RGB Nodes" parm1="1" parm2="25"
           WorldPosX="18" WorldPosY="1"/>
    <model name="Arch R3" DisplayAs="Arches" StringType="RGB Nodes" parm1="1" parm2="25"
           WorldPosX="30" WorldPosY="1"/>
    <!-- 4 candy canes -->
    <model name="Cane 1" DisplayAs="Candy Canes" StringType="RGB Nodes" parm1="1" parm2="30"
           WorldPosX="-24" WorldPosY="0"/>
    <model name="Cane 2" DisplayAs="Candy Canes" StringType="RGB Nodes" parm1="1" parm2="30"
